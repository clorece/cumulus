# Wallpapers are large binaries — track via Git LFS.
# NOTE: install `git lfs` before cloning, or the images arrive as pointer files.
wallpapers/*.jpg   filter=lfs diff=lfs merge=lfs -text
wallpapers/*.jpeg  filter=lfs diff=lfs merge=lfs -text
wallpapers/*.png   filter=lfs diff=lfs merge=lfs -text

# Keep shell/QML/scripts as normal text with LF endings.
*.qml   text eol=lf
*.sh    text eol=lf
*.lua   text eol=lf
*.py    text eol=lf
*.json  text eol=lf
*.md    text eol=lf

# Gallery screenshots (large) via LFS
docs/gallery/*.png  filter=lfs diff=lfs merge=lfs -text

# UI + keyboard sound samples (many small binaries) via LFS
shell/assets/sounds/**/*.wav  filter=lfs diff=lfs merge=lfs -text
